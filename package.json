{
  "name": "route-progress-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:routes && npm run build:app",
    "build:app": "vite build",
    "preview": "vite preview",
    "build:routes": "node scripts/build-routes.mjs",
    "render:instagram": "node scripts/render-instagram.mjs",
    "render:monthly": "MONTHLY=1 node scripts/render-instagram.mjs",
    "render:draft": "FPS=15 OUTPUT=exports/draft-route-map.mp4 npm run render:instagram",
    "render:final": "OUTPUT=exports/instagram-route-map.mp4 npm run render:instagram",
    "render:feed": "WIDTH=1080 HEIGHT=1350 OUTPUT=exports/instagram-feed-4x5.mp4 npm run render:instagram",
    "render:square": "WIDTH=1080 HEIGHT=1080 OUTPUT=exports/instagram-square.mp4 npm run render:instagram"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.10",
    "leaflet": "^1.9.4",
    "vite": "^8.0.10"
  }
}
